# GROQ_API_KEY: Required for Groq llama-3.3-70b-versatile AI calls.
GROQ_API_KEY=

# GEMINI_API_KEY: Required for Gemini AI API calls (Embeddings).
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY=

# MONGO_URI: Optional MongoDB connection string for persistent storage.
MONGO_URI=
